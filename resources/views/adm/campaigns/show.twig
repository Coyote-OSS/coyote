{% extends 'adm.base' %}
{% block title %}Edycja kampanii {{ parent() }}{% endblock %}

{% from 'adm.campaigns.campaignBannerCard' import campaignBannerCard %}

{% block container %}
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span class="me-auto">
        {{ icon('campaign') }}
        Kampania reklamowa
      </span>
      <a class="ms-2 btn btn-sm btn-secondary" href="{{ campaign.editHref }}">
        {{ icon('genericEdit') }}
        Edytuj
      </a>
    </div>

    <div class="list-group list-group-flush">
      <div class="list-group-item">
        <div class="d-flex justify-content-between align-items-center">
          <span>
            {{ icon('genericLink') }}
            <b>Klucz reklamy</b>: <code>{{ campaign.key }}</code>
          </span>
          <span class="text-muted d-none d-lg-block">
            Klucz używany do identyfikacji reklamy i kliknięć.
          </span>
        </div>
      </div>
      <div class="list-group-item">
        {{ icon('genericLink') }}
        <b>Odnośnik reklamy</b>: {{ campaign.redirectUrl }}
      </div>
    </div>
  </div>

  {{ campaignBannerCard(title:'Baner poziomy', banner:bannerHorizontal, imgClass:'banner-horizontal') }}
  {{ campaignBannerCard(title:'Baner boczny', banner:bannerSidebar, imgClass:'banner-sidebar') }}

  <style>
    .banner-horizontal {
      max-width: 256px;
      min-height: 48px;
      min-width: 144px;
    }

    .banner-sidebar {
      max-width: 144px;
      min-width: 100px;
      min-height: 100px;
    }
  </style>
{% endblock %}
